{
  "projectType": "kotlin-java",
  "framework": "spring-boot-3.4.4",
  "jdk": "21",
  "buildTool": "gradle",
  "language": "kotlin",
  "commands": {
    "lint": "./gradlew :apps:commerce-api:ktlintCheck",
    "format": "./gradlew :apps:commerce-api:ktlintFormat",
    "test": "./gradlew :apps:commerce-api:test",
    "build": "./gradlew :apps:commerce-api:build",
    "verify": "./gradlew :apps:commerce-api:ktlintCheck && ./gradlew :apps:commerce-api:test"
  },
  "modules": {
    "apps": ["commerce-api", "commerce-batch", "commerce-streamer"],
    "modules": ["jpa", "redis", "kafka"],
    "supports": ["jackson", "logging", "monitoring"]
  },
  "sensitiveFilePatterns": [
    ".env*",
    "*.key",
    "*.pem",
    "credentials*",
    "application-local.yml"
  ],
  "architecture": {
    "layers": ["interfaces", "application", "domain", "infrastructure"],
    "dependencyDirection": "interfaces → application → domain ← infrastructure"
  },
  "issueKey": {
    "pattern": "^[A-Z]+-[0-9]+$",
    "description": "대문자 영문 1자 이상 + '-' + 숫자 1자 이상 (e.g., JIRA-123, AFS-6)"
  },
  "contextLimits": {
    "product-owner": { "maxInputLines": 500, "note": "PRD 작성에 필요한 요구사항 + 코드 맵" },
    "architect": { "maxInputLines": 1000, "note": "PRD + 코드 맵 + 참조 코드" },
    "design-critic": { "maxInputLines": 800, "note": "설계서 + PRD + 코드 맵" },
    "coder": { "maxInputLines": 2000, "note": "설계서 + 코드 맵 + 참조 코드가 가장 큼" },
    "qa-manager": { "maxInputLines": 1500, "note": "diff가 클 수 있음" },
    "security-auditor": { "maxInputLines": 1500, "note": "PRD + 설계서 + diff" },
    "researcher": { "maxInputLines": 1000, "note": "조사 요청 + 코드 맵" },
    "hacker": { "maxInputLines": 800, "note": "정체 상황 + 코드 맵" },
    "simplifier": { "maxInputLines": 1000, "note": "정체 상황 + 설계서 + PRD + 코드 맵" }
  }
}
