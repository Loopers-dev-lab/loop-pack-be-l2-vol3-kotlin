{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Virtual Users",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "InfluxDB",
      "targets": [
        {
          "query": "SELECT last(\"value\") FROM \"vus\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "InfluxDB",
      "targets": [
        {
          "query": "SELECT count(\"value\") FROM \"http_reqs\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "title": "HTTP Response Time (p95, p99, avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "InfluxDB",
      "targets": [
        {
          "query": "SELECT percentile(\"value\", 95) AS \"p95\", percentile(\"value\", 99) AS \"p99\", mean(\"value\") AS \"avg\" FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "title": "HTTP Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "InfluxDB",
      "targets": [
        {
          "query": "SELECT count(\"value\") FROM \"http_reqs\" WHERE \"status\" != '200' AND \"status\" != '201' AND $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "fillOpacity": 30, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "title": "Order Success / Fail",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": "InfluxDB",
      "targets": [
        {
          "query": "SELECT count(\"value\") FROM \"order_success\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "refId": "A",
          "alias": "success"
        },
        {
          "query": "SELECT count(\"value\") FROM \"order_fail\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "refId": "B",
          "alias": "fail"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "fail" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "title": "Coupon Issue Success / Fail",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": "InfluxDB",
      "targets": [
        {
          "query": "SELECT count(\"value\") FROM \"coupon_success\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "refId": "A",
          "alias": "success"
        },
        {
          "query": "SELECT count(\"value\") FROM \"coupon_fail\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "refId": "B",
          "alias": "fail"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "fail" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "title": "Like Success / Fail",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": "InfluxDB",
      "targets": [
        {
          "query": "SELECT count(\"value\") FROM \"like_success\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "refId": "A",
          "alias": "success"
        },
        {
          "query": "SELECT count(\"value\") FROM \"like_fail\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "refId": "B",
          "alias": "fail"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "fail" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "title": "API Duration by Scenario (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": "InfluxDB",
      "targets": [
        {
          "query": "SELECT percentile(\"value\", 95) FROM \"order_duration\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "refId": "A",
          "alias": "order p95"
        },
        {
          "query": "SELECT percentile(\"value\", 95) FROM \"coupon_duration\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "refId": "B",
          "alias": "coupon p95"
        },
        {
          "query": "SELECT percentile(\"value\", 95) FROM \"like_duration\" WHERE $timeFilter GROUP BY time($__interval)",
          "rawQuery": true,
          "refId": "C",
          "alias": "like p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["k6", "load-test"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
